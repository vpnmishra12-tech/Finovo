
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SMARTKHARCHA AI PRODUCTION SECURITY RULES
     *
     * Core Philosophy:
     * Strict User-Ownership model. Access to data is partitioned by 
     * Firebase Authentication UIDs.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      match /expenses/{expenseId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }

      match /monthlyBudgets/{monthlyBudgetId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
