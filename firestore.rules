
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Explicitly allow reading users for profile checks if needed
    match /users/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      match /expenses/{expenseId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }

      match /monthlyBudgets/{monthlyBudgetId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }

    // Refined Group Rules for better query performance
    match /groups/{groupId} {
      // Re-triggering rules deployment with explicit methods
      allow create: if isSignedIn();
      allow get, list: if isSignedIn() && (request.auth.uid in resource.data.memberIds);
      allow update, delete: if isSignedIn() && (request.auth.uid in resource.data.memberIds);

      match /expenses/{expenseId} {
        allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds);
        allow create: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds);
        allow update, delete: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds) && request.auth.uid == resource.data.paidBy;
      }

      match /members/{memberId} {
        allow read, write: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds);
      }
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
