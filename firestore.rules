
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      match /expenses/{expenseId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }

      match /monthlyBudgets/{monthlyBudgetId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }

    match /groups/{groupId} {
      allow create: if isSignedIn();
      // Allow reading if the user is in the memberIds array
      allow get: if isSignedIn() && (request.auth.uid in resource.data.memberIds);
      allow list: if isSignedIn() && (request.auth.uid in resource.data.memberIds);
      
      // Allow update for joining (adding self to memberIds) OR if already a member
      allow update: if isSignedIn() && (
        (request.resource.data.memberIds.hasAll(resource.data.memberIds) && request.resource.data.memberIds.hasAny([request.auth.uid])) ||
        (request.auth.uid in resource.data.memberIds)
      );
      
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.createdBy);

      match /expenses/{expenseId} {
        // Use get() with extreme care or prefer list-ready checks
        allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds);
        allow create: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds);
        allow update, delete: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds) && request.auth.uid == resource.data.paidBy;
      }

      match /members/{memberId} {
        allow read, write: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds);
      }
    }

    match /categories/{categoryId} {
      allow read: if true;
    }
  }
}
