
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isGroupMember(groupId) {
      // Basic rule: if your UID is in the group's memberIds array
      return isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds);
    }

    match /users/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      match /expenses/{expenseId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }

      match /monthlyBudgets/{monthlyBudgetId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }

    match /groups/{groupId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isGroupMember(groupId);

      match /expenses/{expenseId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId);
        allow update, delete: if isGroupMember(groupId) && request.auth.uid == resource.data.paidBy;
      }

      match /members/{memberId} {
        allow read, write: if isGroupMember(groupId);
      }
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
